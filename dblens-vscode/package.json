{
  "name": "dblens-vscode",
  "displayName": "DBLens Companion",
  "description": "Start the DBLens Next.js application locally from within VS Code",
  "version": "0.2.0",
  "publisher": "asiff",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/asiffmahmad/DBLens.asiff.dev"
  },
  "homepage": "https://github.com/asiffmahmad/DBLens.asiff.dev#readme",
  "bugs": {
    "url": "https://github.com/asiffmahmad/DBLens.asiff.dev/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "keywords": [
    "database",
    "dblens",
    "schema",
    "validator"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dblens.startLocal",
        "title": "DBLens: Start Local Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "tsc -p ./ --noEmit",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "typescript": "^5.1.6"
  }
}
